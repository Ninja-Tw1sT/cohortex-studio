# Copy to .env (gitignored) and fill in real values. Nothing here has a secret
# default — MONGODB_URI and SIDECAR_URL point at localhost for local dev.

PORT=3000
# Local dev points at a local Mongo. In prod, use an Atlas connection string
# (mongodb+srv://user:pass@cluster.mongodb.net/cohortex_studio).
MONGODB_URI=mongodb://127.0.0.1:27017/cohortex_studio

# FastAPI sidecar this backend proxies runs to.
SIDECAR_URL=http://localhost:8000

# Optional shared secret sent as the X-Sidecar-Key header on every sidecar
# request. Leave unset for local dev. Set the same value here and in
# sidecar/.env to require it in shared/deployed environments.
SIDECAR_SHARED_KEY=

# Firebase Admin SDK credentials, used to verify ID tokens from the frontend.
# Local dev: download from Firebase console > Project settings > Service
# accounts > Generate new private key, save as backend/serviceAccountKey.json
# (gitignored). On Cloud Run, leave this unset — the attached runtime service
# account is used automatically via Application Default Credentials.
# Requests without a Bearer token still work — they're treated as anonymous
# and only see the public demo namespace.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Comma-separated list of origins allowed to call this API. Leave unset for
# local dev (allows any origin). Set to the Firebase Hosting URL(s) in prod.
ALLOWED_ORIGINS=

# Set to "false" to reject live runs with a clean 403 instead of timing out
# against a sidecar that isn't deployed. The public demo deployment has no
# LLM backend wired up, so it runs replay-only.
LIVE_RUNS_ENABLED=true
