# Copy to .env (gitignored) and fill in real values. Ollama needs no key, so
# every provider var below is optional — only set the ones for backends you use.

# Optional shared secret this sidecar requires on X-Sidecar-Key. Leave unset
# to accept unauthenticated requests (fine for local dev behind a firewall).
# Must match backend/.env's SIDECAR_SHARED_KEY when set.
SIDECAR_SHARED_KEY=

# Local model backend (default, no key required).
OLLAMA_BASE_URL=http://localhost:11434

# Cloud provider keys — only needed for agents configured to use these backends.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
